{
  "expo": {
    "name": "BEN IA",
    "slug": "ben-ia-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1f3c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.adv.mauromoncao.benia",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera não usada.",
        "NSMicrophoneUsageDescription": "Microfone não usado.",
        "CFBundleDisplayName": "BEN IA"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0d1f3c"
      },
      "package": "br.adv.mauromoncao.benia",
      "versionCode": 2,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "scheme": "benia",
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "ben-ia-app"
      }
    }
  }
}
