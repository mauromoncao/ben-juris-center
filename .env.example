# ============================================================
# BEN JURIS CENTER — Variáveis de Ambiente (Vercel)
# Configure em: Cloudflare Pages / VPS Hostinger → Environment Variables
# Ambiente: Production + Preview
# ============================================================

# ── OBRIGATÓRIAS — sem elas o sistema não funciona ──────────

# Claude / Anthropic (agentes jurídicos principais)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (fallback e agentes GPT-4o)
OPENAI_API_KEY=sk-proj-...

# Perplexity (busca de jurisprudência atualizada)
PERPLEXITY_API_KEY=pplx-...

# ── MEMÓRIA VETORIAL (Pinecone) ──────────────────────────────
# Crie índice em: https://app.pinecone.io
# Dimensões: 768 (text-embedding-004 do Gemini)
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_HOST=https://SEU-INDICE.svc.REGIÃO.pinecone.io

# Gemini (embeddings para Pinecone)
# GEMINI_API_KEY removido — embeddings via OpenAI (text-embedding-3-small, 1536 dims)

# ── VPS HOSTINGER ────────────────────────────────────────────
# IP do servidor: 181.215.135.202
# Porta 3001: Leads API + Monitor + DB Proxy (server.js)
# Porta 3600: Portal do Cliente (vps-portal-server/server.js)
VPS_LEADS_URL=http://181.215.135.202:3001

# Token para autenticar chamadas ao /db/query no VPS
# Deve ser igual ao DB_TOKEN configurado no .env do VPS
DB_TOKEN=seu-token-seguro-aqui

# ── WHATSAPP (notificações urgentes ao plantonista) ──────────
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_TOKEN=...
PLANTONISTA_WHATSAPP=5586999484761

# ── ASAAS (pagamentos/cobranças) ─────────────────────────────
ASAAS_API_KEY=...

# ── CNJ / DATAJUD (consulta processual) ─────────────────────
DATAJUD_API_KEY=...

# ── ELEVENLABS (síntese de voz) ──────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# ── EMAIL (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
ESCRITORIO_EMAIL=mauromoncaoadv.escritorio@gmail.com

# ── AUTENTICAÇÃO JWT (Portal do Cliente) ─────────────────────
JWT_SECRET=ben-portal-secret-2026-TROQUE-ESTE-VALOR

# ── CRONS (Vercel Cron Jobs) ──────────────────────────────────
# Token de autenticação para os cron jobs
CRON_SECRET=seu-cron-secret

# ── SUPABASE (opcional — backup/histórico) ────────────────────
SUPABASE_REST_URL=https://SEU-PROJETO.supabase.co/rest/v1
SUPABASE_ANON_KEY=eyJ...

# ── AWS S3 (opcional — armazenamento de documentos) ──────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── URLs internas ────────────────────────────────────────────
